@dp.callback_query(F.data.startswith("bj|"))
async def cb_blackjack(callback: types.CallbackQuery):
    _, action, uid_s = callback.data.split("|")
    uid = int(uid_s)

    if callback.from_user.id != uid:
        return await callback.answer("❌ Это не твоя игра!", show_alert=True)

    with bj_lock:
        game = bj_games.get(uid)
    if not game:
        return await callback.answer("❌ Игра устарела, начни заново", show_alert=True)

    player, dealer, bet = game["player"], game["dealer"], game["bet"]

    if action == "hit":
        player.append(bj_card())
        pval = bj_value(player)
        with bj_lock:
            bj_games[uid]["player"] = player

        if pval > 21:
            with bj_lock: bj_games.pop(uid, None)
            db_exec("UPDATE users SET losses=losses+1 WHERE id=?", (uid,))
            return await callback.message.edit_text(
                f"🃏 <b>Перебор!</b>\nКарты: {' '.join(player)} = <b>{pval}</b>\n💸 -{bet:,}💰",
                parse_mode="HTML"
            )
        if pval == 21:
            action = "stand"
        else:
            builder = InlineKeyboardBuilder()
            builder.row(
                types.InlineKeyboardButton(text="🃏 Ещё карту", callback_data=f"bj|hit|{uid}"),
                types.InlineKeyboardButton(text="✋ Хватит",    callback_data=f"bj|stand|{uid}"),
            )
            return await callback.message.edit_text(
                f"🃏 <b>Блэкджек</b> | Ставка: {bet:,}💰\n"
                f"━━━━━━━━━━━━━━\n"
                f"Твои карты: {' '.join(player)} = <b>{pval}</b>\n"
                f"Дилер: {dealer[0]} | ?",
                reply_markup=builder.as_markup(), parse_mode="HTML"
            )

    # stand
    pval = bj_value(player)
    while bj_value(dealer) < 17:
        dealer.append(bj_card())
    dval = bj_value(dealer)
    with bj_lock: bj_games.pop(uid, None)

    if dval > 21 or pval > dval:
        win = bet * 2
        db_exec("UPDATE users SET balance=balance+?,total_earned=total_earned+?,wins=wins+1 WHERE id=?", (win,win,uid))
        add_exp_lvl(uid, 20)
        result = f"🏆 Победа! +<b>{bet:,}💰</b>"
    elif pval == dval:
        db_exec("UPDATE users SET balance=balance+? WHERE id=?", (bet, uid))
        result = "🤝 Ничья! Ставка возвращена."
    else:
        db_exec("UPDATE users SET losses=losses+1 WHERE id=?", (uid,))
        add_exp_lvl(uid, 5)
        result = f"❌ Дилер победил! -{bet:,}💰"

    await callback.message.edit_text(
        f"🃏 <b>Итог</b>\n"
        f"━━━━━━━━━━━━━━\n"
        f"Ты: {' '.join(player)} = <b>{pval}</b>\n"
        f"Дилер: {' '.join(dealer)} = <b>{dval}</b>\n"
        f"━━━━━━━━━━━━━━\n{result}",
        parse_mode="HTML"
    )

