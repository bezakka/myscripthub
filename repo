async def handle_rp(message: types.Message, action_key: str):
    uid  = message.from_user.id
    wait = check_cd(uid, "rp")
    if wait:
        return await message.answer(f"⏱ Подожди <b>{wait}с</b>!", parse_mode="HTML")

    if not message.reply_to_message:
        a = RP_ACTIONS[action_key]
        return await message.answer(f"{a['emoji']} Ответь на сообщение нужного человека!")

    target = message.reply_to_message.from_user
    if target.id == uid:
        return await message.answer("😅 Ты пытаешься сделать это с собой?")

    tmpl = random.choice(RP_ACTIONS[action_key]["texts"])
    fn   = f'<a href="tg://user?id={uid}">{message.from_user.first_name}</a>'
    tn   = f'<a href="tg://user?id={target.id}">{target.first_name}</a>'
    await message.answer(tmpl.replace("{f}", fn).replace("{t}", tn), parse_mode="HTML")

for _a in list(RP_ACTIONS.keys()) + list(RP_ALIASES.keys()):
    def _make(key):
        resolved = RP_ALIASES.get(key, key)
        async def _h(message: types.Message):
            await handle_rp(message, resolved)
        return _h
    dp.message.register(_make(_a), Command(_a))

