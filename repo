DB_PATH = "game.db"
db_lock = Lock()

def db_exec(query: str, params=(), fetch=None):
    with db_lock:
        conn = sqlite3.connect(DB_PATH, check_same_thread=False)
        try:
            cur = conn.cursor()
            cur.execute(query, params)
            result = None
            if fetch == 'one':  result = cur.fetchone()
            elif fetch == 'all': result = cur.fetchall()
            conn.commit()
            return result
        except Exception as e:
            logging.error(f"DB ERROR: {e} | query={query} | params={params}")
            conn.rollback()
            return None
        finally:
            conn.close()

def db_many(queries: list):
    with db_lock:
        conn = sqlite3.connect(DB_PATH, check_same_thread=False)
        try:
            cur = conn.cursor()
            for q, p in queries:
                cur.execute(q, p)
            conn.commit()
        except Exception as e:
            logging.error(f"DB MANY ERROR: {e}")
            conn.rollback()
        finally:
            conn.close()

def init_db():
    with db_lock:
        conn = sqlite3.connect(DB_PATH, check_same_thread=False)
        cur  = conn.cursor()

        # Основная таблица
        cur.execute('''CREATE TABLE IF NOT EXISTS users (
            id            INTEGER PRIMARY KEY,
            username      TEXT    DEFAULT 'Игрок',
            balance       INTEGER DEFAULT 1000,
            exp           INTEGER DEFAULT 0,
            lvl           INTEGER DEFAULT 1,
            wins          INTEGER DEFAULT 0,
            losses        INTEGER DEFAULT 0,
            total_earned  INTEGER DEFAULT 0,
            total_lost    INTEGER DEFAULT 0,
            last_daily    TEXT    DEFAULT '',
            reputation    INTEGER DEFAULT 0,
            inventory     TEXT    DEFAULT '',
            registered_at TEXT    DEFAULT CURRENT_TIMESTAMP
        )''')

        # Миграция — добавляем колонки если их нет (для старых БД)
        existing = [row[1] for row in cur.execute("PRAGMA table_info(users)").fetchall()]
        migrations = {
            "reputation": "INTEGER DEFAULT 0",
            "inventory":  "TEXT DEFAULT ''",
        }
        for col, definition in migrations.items():
            if col not in existing:
                cur.execute(f"ALTER TABLE users ADD COLUMN {col} {definition}")
                logging.info(f"Migrated: added column {col}")

        cur.execute('''CREATE TABLE IF NOT EXISTS duels (
            id            INTEGER PRIMARY KEY AUTOINCREMENT,
            challenger_id INTEGER,
            opponent_id   INTEGER,
            bet           INTEGER,
            winner_id     INTEGER,
            chal_roll     INTEGER DEFAULT 0,
            opp_roll      INTEGER DEFAULT 0,
            created_at    TEXT    DEFAULT CURRENT_TIMESTAMP
        )''')

        cur.execute('''CREATE TABLE IF NOT EXISTS bets (
            id         INTEGER PRIMARY KEY AUTOINCREMENT,
            user_id    INTEGER,
            amount     INTEGER,
            game       TEXT,
            won        INTEGER,
            created_at TEXT DEFAULT CURRENT_TIMESTAMP
        )''')

        cur.execute('''CREATE TABLE IF NOT EXISTS shop_items (
            id          INTEGER PRIMARY KEY AUTOINCREMENT,
            name        TEXT,
            emoji       TEXT,
            price       INTEGER,
            description TEXT,
            effect      TEXT
        )''')

        cur.execute('''CREATE TABLE IF NOT EXISTS marriages (
            id         INTEGER PRIMARY KEY AUTOINCREMENT,
            user1_id   INTEGER,
            user2_id   INTEGER,
            created_at TEXT DEFAULT CURRENT_TIMESTAMP
        )''')

        # Заполняем магазин если пустой
        if cur.execute("SELECT COUNT(*) FROM shop_items").fetchone()[0] == 0:
            items = [
                ("Удочка",          "🎣", 500,  "Улучшает рыбалку (+25%)",          "fish_bonus"),
                ("Кирка",           "⛏️", 800,  "Улучшает добычу руды (+30%)",      "mine_bonus"),
                ("Пистолет",        "🔫", 1200, "Усиляет охоту (+35%)",             "hunt_bonus"),
                ("Маска",           "🎭", 600,  "Снижает риск при крайм (-15%)",    "crime_bonus"),
                ("Счастливый кубик","🍀", 1500, "Улучшает шансы в /dice",           "luck"),
                ("VIP карта",       "💳", 5000, "+20% к заработку на работе",        "vip"),
                ("Броня",           "🛡️", 2000, "Защита в дуэлях (+1 к броску)",   "armor"),
                ("Энергетик",       "⚡", 200,  "Снимает кулдаун работы",           "energy"),
            ]
            cur.executemany(
                "INSERT INTO shop_items (name,emoji,price,description,effect) VALUES (?,?,?,?,?)",
                items
            )

        conn.commit()
        conn.close()
        logging.info("DB initialized OK")

init_db()

