@dp.message(Command("give"))
async def cmd_give(message: types.Message):
    uid  = message.from_user.id
    wait = check_cd(uid, "give")
    if wait:
        return await message.answer(f"⏱ Подожди <b>{wait}с</b>!", parse_mode="HTML")

    # Проверяем reply
    if not message.reply_to_message:
        return await message.answer(
            "❌ <b>Как переводить:</b>\n"
            "Ответь на сообщение нужного человека командой /give 500",
            parse_mode="HTML"
        )

    args = message.text.split()
    if len(args) < 2:
        return await message.answer("❌ Укажи сумму: /give 500")

    try:
        amount = int(args[1])
    except ValueError:
        return await message.answer("❌ Сумма должна быть числом")

    if amount <= 0:
        return await message.answer("❌ Сумма должна быть > 0")

    target = message.reply_to_message.from_user
    if target.id == uid:
        return await message.answer("❌ Нельзя переводить себе")
    if target.is_bot:
        return await message.answer("❌ Нельзя переводить боту")

    get_user(uid, message.from_user.first_name)
    get_user(target.id, target.first_name)  # авторегистрация

    bal = get_balance(uid)
    if bal < amount:
        return await message.answer(f"❌ Недостаточно! У тебя: <b>{bal:,}💰</b>", parse_mode="HTML")

    db_many([
        ("UPDATE users SET balance=balance-? WHERE id=?", (amount, uid)),
        ("UPDATE users SET balance=balance+? WHERE id=?", (amount, target.id)),
    ])
    await message.answer(
        f"✅ <b>{message.from_user.first_name}</b> → <b>{target.first_name}</b>\n"
        f"💰 <b>{amount:,}</b>",
        parse_mode="HTML"
    )

