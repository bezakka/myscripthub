def get_user(uid, username=None):
    row = db_exec("SELECT * FROM users WHERE id=?", (uid,), fetch='one')
    if row is None:
        name = username or "Игрок"
        db_exec("INSERT INTO users (id, username) VALUES (?,?)", (uid, name))
        row = db_exec("SELECT * FROM users WHERE id=?", (uid,), fetch='one')
    elif username and username != row[1]:
        db_exec("UPDATE users SET username=? WHERE id=?", (username, uid))
    return row

def get_balance(uid) -> int:
    row = db_exec("SELECT balance FROM users WHERE id=?", (uid,), fetch='one')
    if row is None:
        get_user(uid)
        return 0
    return row[0]  # 0 — тоже валидный баланс!

def get_username_db(uid) -> str:
    row = db_exec("SELECT username FROM users WHERE id=?", (uid,), fetch='one')
    return row[0] if row is not None else "Игрок"

def get_inventory(uid) -> list:
    row = db_exec("SELECT inventory FROM users WHERE id=?", (uid,), fetch='one')
    if row is None or not row[0]:
        return []
    return [e for e in row[0].split(",") if e.strip()]

def has_item(uid, effect) -> bool:
    return effect in get_inventory(uid)

def add_to_inventory(uid, effect):
    inv = get_inventory(uid)
    if effect not in inv:
        inv.append(effect)
        db_exec("UPDATE users SET inventory=? WHERE id=?", (",".join(inv), uid))

def remove_from_inventory(uid, effect):
    inv = get_inventory(uid)
    if effect in inv:
        inv.remove(effect)
        db_exec("UPDATE users SET inventory=? WHERE id=?", (",".join(inv), uid))

def add_exp_lvl(uid, amount) -> list:
    user = get_user(uid)
    balance, exp, lvl = user[2], user[3], user[4]
    new_exp = exp + amount
    msgs = []
    while new_exp >= lvl * 100 and lvl < 100:
        new_exp -= lvl * 100
        lvl     += 1
        reward   = lvl * 300
        balance += reward
        msgs.append(f"🎉 Уровень <b>{lvl}</b>! +{reward:,}💰")
    db_exec("UPDATE users SET exp=?,lvl=?,balance=? WHERE id=?", (new_exp, lvl, balance, uid))
    return msgs

def get_rank(lvl) -> str:
    if lvl >= 90: return "🌟 Бог"
    if lvl >= 80: return "👑 Легенда"
    if lvl >= 60: return "💎 Мастер"
    if lvl >= 40: return "🥇 Ветеран"
    if lvl >= 20: return "🥈 Опытный"
    if lvl >= 10: return "🥉 Новичок+"
    return "🔰 Новичок"

def pbar(exp, mx, n=10) -> str:
    f = int((exp / max(mx, 1)) * n)
    return "█" * f + "░" * (n - f)

def is_married(uid):
    return db_exec(
        "SELECT * FROM marriages WHERE user1_id=? OR user2_id=?",
        (uid, uid), fetch='one'
    )

