# ── Вспомогательная: найти юзера из аргументов или reply ──
def resolve_target(message: types.Message, args: list):
    """
    Возвращает (user_id, username, error_text)
    Ищет через reply или через @username в аргументах
    """
    if message.reply_to_message:
        t = message.reply_to_message.from_user
        return t.id, t.first_name, None

    # Ищем @username в аргументах
    for arg in args[1:]:
        if arg.startswith("@"):
            uname = arg[1:]
            row = db_exec("SELECT id, username FROM users WHERE LOWER(username)=LOWER(?)",
                          (uname,), fetch='one')
            if row:
                return row[0], row[1], None
            return None, None, f"❌ Пользователь @{uname} не найден в БД"

    return None, None, "❌ Укажи @юзера или ответь на его сообщение"

def parse_amount(args: list) -> tuple:
    """Ищет число в аргументах, возвращает (число, ошибка)"""
    for arg in args:
        try:
            val = int(arg)
            return val, None
        except ValueError:
            continue
    return None, "❌ Укажи числовое значение"

