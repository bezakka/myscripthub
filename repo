_cd_store = defaultdict(dict)
_cd_lock  = Lock()
COOLDOWNS = {"dice": 3, "slots": 5, "coin": 3, "bet": 4, "duel": 8, "give": 5, "rp": 3}

def check_cd(uid: int, cmd: str) -> float:
    cd = COOLDOWNS.get(cmd, 3)
    with _cd_lock:
        last    = _cd_store[uid].get(cmd, 0)
        elapsed = time.time() - last
        if elapsed < cd:
            return round(cd - elapsed, 1)
        _cd_store[uid][cmd] = time.time()
        return 0

_work_cd     = {}
_work_cd_lock = Lock()
WORK_CD = {"work": 3600, "crime": 1800, "mine": 7200, "fish": 2700, "hunt": 5400}

def check_work_cd(uid: int, cmd: str) -> int:
    key = f"{uid}_{cmd}"
    with _work_cd_lock:
        last    = _work_cd.get(key, 0)
        elapsed = time.time() - last
        cd      = WORK_CD.get(cmd, 3600)
        if elapsed < cd:
            return int(cd - elapsed)
        _work_cd[key] = time.time()
        return 0

def fmt_time(s: int) -> str:
    h, rem = divmod(s, 3600)
    m, sec = divmod(rem, 60)
    if h:   return f"{h}ч {m}м"
    if m:   return f"{m}м {sec}с"
    return f"{sec}с"

