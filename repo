@dp.message(Command("dice"))
async def cmd_dice(message: types.Message):
    uid  = message.from_user.id
    wait = check_cd(uid, "dice")
    if wait:
        return await message.answer(f"⏱ Подожди <b>{wait}с</b>!", parse_mode="HTML")
    get_user(uid, message.from_user.first_name)

    args = message.text.split()
    bet  = 0
    if len(args) > 1:
        try:
            bet = int(args[1])
            if bet <= 0:
                return await message.answer("❌ Ставка > 0")
            bal = get_balance(uid)
            if bet > bal:
                return await message.answer(f"❌ Недостаточно! У тебя: {bal:,}💰")
            db_exec("UPDATE users SET balance=balance-?,total_lost=total_lost+? WHERE id=?", (bet,bet,uid))
        except ValueError:
            return await message.answer("❌ /dice 500")

    msg   = await message.answer_dice(emoji="🎲")
    value = msg.dice.value
    await asyncio.sleep(3)

    if bet > 0:
        if has_item(uid, "luck"):
            mults = {1:0, 2:0, 3:0.9, 4:1.4, 5:1.9, 6:3.0}
        else:
            mults = {1:0, 2:0, 3:0,   4:1.2, 5:1.5, 6:2.5}
        mult = mults[value]
        win  = int(bet * mult)
        if win > 0:
            profit = win - bet
            db_many([
                ("UPDATE users SET balance=balance+?,total_earned=total_earned+?,wins=wins+1 WHERE id=?", (win,win,uid)),
                ("INSERT INTO bets (user_id,amount,game,won) VALUES(?,?,'dice',1)", (uid,bet)),
            ])
            result = f"✅ x{mult}! +<b>{profit:,}💰</b>" if profit > 0 else f"↩️ Почти... (<b>-{bet-win:,}💰</b>)"
        else:
            db_many([
                ("UPDATE users SET losses=losses+1 WHERE id=?", (uid,)),
                ("INSERT INTO bets (user_id,amount,game,won) VALUES(?,?,'dice',0)", (uid,bet)),
