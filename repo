@dp.message(Command("broadcast"))
async def cmd_broadcast(message: types.Message):
    if not is_admin(message): return await message.answer("❌ Нет прав!")

    args  = message.text.split(maxsplit=1)
    if len(args) < 2:
        return await message.answer("❌ Укажи текст: /broadcast Привет всем!")

    text  = args[1]
    users = db_exec("SELECT id FROM users", fetch='all')
    if not users:
        return await message.answer("❌ Нет пользователей")

    sent = 0
    fail = 0
    for (uid,) in users:
        try:
            await bot.send_message(uid, f"📢 <b>Объявление:</b>\n\n{text}", parse_mode="HTML")
            sent += 1
            await asyncio.sleep(0.05)  # защита от флуда
        except:
            fail += 1

    await message.answer(
        f"📢 <b>Рассылка завершена</b>\n"
        f"✅ Отправлено: <b>{sent}</b>\n"
        f"❌ Ошибок: <b>{fail}</b>",
        parse_mode="HTML"
    )

