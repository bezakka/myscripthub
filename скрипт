                                isEnemy = true
                            end
                        end
                        
                        -- Інші гравці (PvP)
                        if enemy:IsA("Player") and enemy ~= player and enemy.Character and enemy.Character:FindFirstChild("Humanoid") then
                            isEnemy = true
                        end
                        
                        if isEnemy then
                            local enemyRoot = enemy:IsA("Player") and enemy.Character.HumanoidRootPart or enemy:FindFirstChild("HumanoidRootPart")
