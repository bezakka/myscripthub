-- Константы для полета
local lp = game.Players.LocalPlayer
local flySpeed = 50
local flying = false
local bv, bg

-- Функция полета для мобилок
local function toggleFly(state)
    flying = state
    local char = lp.Character or lp.CharacterAdded:Wait()
    local root = char:WaitForChild("HumanoidRootPart")

    if flying then
        bv = Instance.new("BodyVelocity")
        bv.MaxForce = Vector3.new(1e6, 1e6, 1e6)
        bv.Velocity = Vector3.new(0, 0, 0)
        bv.Parent = root

        bg = Instance.new("BodyGyro")
        bg.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
        bg.P = 10000
        bg.Parent = root

        task.spawn(function()
            while flying and task.wait() do
                local cam = workspace.CurrentCamera
                -- На мобилках летим туда, куда смотрит камера
                bv.Velocity = cam.CFrame.LookVector * flySpeed
                bg.CFrame = cam.CFrame
            end
            if bv then bv:Destroy() end
            if bg then bg:Destroy() end
        end)
    end
end

-- Слайдер скорости
Tabs.Main:AddSlider("FlySpeed", {
    Title = "Скорость полета",
    Description = "Не ставь слишком много, чтобы не кикнуло",
    Default = 50,
    Min = 0,
    Max = 300,
    Rounding = 0,
    Callback = function(Value)
        flySpeed = Value
    end
})

-- Включалка полета
Tabs.Main:AddToggle("FlyToggle", {
    Title = "Режим полета",
    Default = false,
    Callback = function(Value)
        toggleFly(Value)
    end
})

