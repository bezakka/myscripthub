--[[
    Δ ИМБОВИЙ ЧИТ ДЛЯ FISH IT (FISCH) Δ
    Функції: телепорт, авто-рибалка, прискорення, ESP
    Використовуй з розумом на свій страх і ризик.
]]

-- Перевіряємо, чи є гра, і створюємо головне меню
local player = game:GetService("Players").LocalPlayer
local workspace = game:GetService("Workspace")
local runService = game:GetService("RunService")
local userInputService = game:GetService("UserInputService")
local tweenService = game:GetService("TweenService")
local virtualUser = game:GetService("VirtualUser")
local camera = workspace.CurrentCamera

-- Змінні для стану читів
local speedEnabled = false
local speedValue = 64 -- Значення за замовчуванням
local flyEnabled = false
local flyConnection = nil
local autoFishEnabled = false
local autoFishConnection = nil
local espEnabled = false
local espConnections = {}
local teleportWaypoints = {} -- Для збереження точок телепорту

-- Головне GUI
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "FishItProGUI"
