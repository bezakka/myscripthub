-- Anti-cheat bypass
local function SafeTP(pos)
    local origin = HRP.CFrame
    local goal = CFrame.new(pos)
    for i = 1, 8 do
        HRP.CFrame = origin:Lerp(goal, i/8)
        task.wait(0.04)
    end
end

-- Поиск мобов
local function GetMob(isBoss)
    local nearest, dist = nil, math.huge
    for _, m in ipairs(workspace:GetDescendants()) do
        if m:IsA("Model") and m ~= Character then
            local hum = m:FindFirstChildOfClass("Humanoid")
            local hrp = m:FindFirstChild("HumanoidRootPart")
            if hum and hrp and hum.Health > 0 then
                -- Проверка на босса (по имени или размеру)
                local isBossCheck = m.Name:lower():find("boss") or m.Name:lower():find("factory") or hum.MaxHealth > 5000
                if isBoss and not isBossCheck then continue end
                if not isBoss and isBossCheck then continue end
                
                local d = (HRP.Position - hrp.Position).Magnitude
                if d < dist and d < Config.FarmRadius then
                    dist, nearest = d, {hrp = hrp, hum = hum}
                end
            end
        end
    end
    return nearest
end

-- Поиск сундуков
local function GetChest()
    local nearest, dist = nil, math.huge
    for _, v in ipairs(workspace:GetDescendants()) do
        if v.Name:lower():find("chest") or v.Name:lower():find("box") then
            if v:IsA("Part") or v:IsA("Model") then
                local pos = v:IsA("Model") and v.PrimaryPart and v.PrimaryPart.Position or v.Position
                if pos then
                    local d = (HRP.Position - pos).Magnitude
                    if d < dist and d < 100 then
                        dist, nearest = d, pos
                    end
                end
            end
        end
    end
    return nearest
end

-- Авто Хаки
local function UseHaki()
    if Config.AutoHaki then
        local args = {
            [1] = "Activate",
            [2] = "Observation"
        }
        game:GetService("ReplicatedStorage"):WaitForChild("Remotes"):WaitForChild("Haki"):InvokeServer(unpack(args))
        
        wait(2)
        
        local args2 = {
            [1] = "Activate",
            [2] = "Armament"
        }
        game:GetService("ReplicatedStorage"):WaitForChild("Remotes"):WaitForChild("Haki"):InvokeServer(unpack(args2))
    end
end

-- Полёт
local BodyVel, BodyGyro

local function EnableFlight()
    Humanoid.PlatformStand = true
    BodyVel = Instance.new("BodyVelocity")
    BodyVel.MaxForce = Vector3.new(1e5,1e5,1e5)
    BodyVel.Velocity = Vector3.zero
    BodyVel.Parent = HRP
    
    BodyGyro = Instance.new("BodyGyro")
    BodyGyro.MaxTorque = Vector3.new(1e5,1e5,1e5)
    BodyGyro.D = 50
    BodyGyro.Parent = HRP
    
    -- Управление полетом
    local flightLoop
    flightLoop = RunService.Heartbeat:Connect(function()
        if Config.Flight and BodyVel then
            BodyVel.Velocity = Vector3.new(0, 20, 0)
        end
    end)
end

local function DisableFlight()
    Config.Flight = false
    Humanoid.PlatformStand = false
    if BodyVel then BodyVel:Destroy() BodyVel = nil end
    if BodyGyro then BodyGyro:Destroy() BodyGyro = nil end
end

