task.spawn(function()
    while task.wait(0.15) do
        pcall(function()
            -- Auto Farm
            if Config.AutoFarm then
                local mob = GetMob(false)
                if mob then
                    if (HRP.Position - mob.hrp.Position).Magnitude > 7 then
                        SafeTP(mob.hrp.Position + Vector3.new(0, 3, 4))
                    end
                    Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                end
            end
            
            -- Auto Boss
            if Config.AutoBoss then
                local boss = GetMob(true)
                if boss then
                    if (HRP.Position - boss.hrp.Position).Magnitude > 7 then
                        SafeTP(boss.hrp.Position + Vector3.new(0, 3, 4))
                    end
                    Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                end
            end
            
            -- Auto Chest
            if Config.AutoChest then
                local chestPos = GetChest()
                if chestPos then
                    if (HRP.Position - chestPos).Magnitude > 5 then
                        SafeTP(chestPos + Vector3.new(0, 2, 0))
                    end
                end
            end
            
            -- Auto Haki (каждые 30 секунд)
            if Config.AutoHaki and tick() % 30 < 0.1 then
                UseHaki()
            end
        end)
    end
end)

